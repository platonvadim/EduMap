    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:relative": "VITE_BASE_PATH=./ vite build --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts --host 0.0.0.0",
    "build:platon": "cross-env VITE_BASE_PATH=/edumap/ vite build",
    "preview:platon": "vite preview --config vite.config.ts --host 0.0.0.0"
  },
  "devDependencies": {
    "@radix-ui/react-scroll-area": "^1.2.4",
